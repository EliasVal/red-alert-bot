{
  "compilerOptions": {
    "strict": true,
    "erasableSyntaxOnly": true,
    "noImplicitAny": true,
    "target": "esnext",
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    
    "types": ["node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules/**"]
}